{
  "name": "@snowyyd/create-template",
  "description": "A TypeScript project template creator",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "homepage": "https://github.com/snowyyd/typescript-template#readme",
  "repository": "https://github.com/snowyyd/typescript-template.git",
  "bugs": "https://github.com/snowyyd/typescript-template/issues",
  "license": "MIT",
  "main": "bin/main.js",
  "bin": {
    "@snowyyd/create-template": "bin/main.js"
  },
  "scripts": {
    "prepack": "pnpm build",
    "lint": "eslint src/ eslint.config.mjs",
    "check": "tsc",
    "build": "tsc -p tsconfig.build.json --outDir bin/",
    "dev": "node src/main.ts",
    "dev:tsx": "tsx src/main.ts"
  },
  "devDependencies": {
    "@snowyyd/eslint-config": "^2.2.7",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@topcli/prompts": "^4.0.0",
    "tinyglobby": "^0.2.17"
  }
}
